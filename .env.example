# ─── Core ────────────────────────────────────────────────────────────────────
DATABASE_URL=postgres://user:pass@localhost:5432/koapos
SESSION_SECRET=change-me-to-a-long-random-string

# ─── Token Vault ──────────────────────────────────────────────────────────────
# Optional: dedicated 32+ char string for AES-256-CBC token encryption.
# Falls back to SESSION_SECRET if not set.
VAULT_ENCRYPTION_KEY=change-me-to-a-32char-random-string

# ─── Cloud Storage ────────────────────────────────────────────────────────────
# Google (shared client for Drive, Business Profile, Contacts/Calendar)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Microsoft (shared client for OneDrive, Contacts/Calendar)
MICROSOFT_CLIENT_ID=
MICROSOFT_CLIENT_SECRET=

# Dropbox
DROPBOX_APP_KEY=
DROPBOX_APP_SECRET=

# ─── Business & Finance ───────────────────────────────────────────────────────
# Xero
XERO_CLIENT_ID=
XERO_CLIENT_SECRET=

# QuickBooks Online (Intuit)
QUICKBOOKS_CLIENT_ID=
QUICKBOOKS_CLIENT_SECRET=

# Stripe Connect (for merchants connecting their own Stripe account)
STRIPE_CONNECT_CLIENT_ID=
STRIPE_SECRET_KEY=

# ─── Social Media & Marketing ─────────────────────────────────────────────────
# Meta (Facebook & Instagram Business)
META_APP_ID=
META_APP_SECRET=

# Twitter / X
TWITTER_CLIENT_ID=
TWITTER_CLIENT_SECRET=

# LinkedIn
LINKEDIN_CLIENT_ID=
LINKEDIN_CLIENT_SECRET=

# TikTok for Business
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
